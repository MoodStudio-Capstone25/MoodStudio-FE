{
  "expo": {
    "name": "MoodStudio",
    "slug": "moodstudio",
    "scheme": "moodstudio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.seunghyeonkang.moodstudio",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.seunghyeonkang.moodstudio"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-asset",
        {
          "assets": [
            "./assets/fonts/Tenada.ttf"
          ]
        }
      ]
    ],
    "owner": "seunghyeonkang",
    "extra": {
      "eas": {
        "projectId": "40ab010a-45c5-4b2f-a262-7e5237a22e91"
      }
    }
  }
}
